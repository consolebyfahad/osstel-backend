# Copy to .env and fill in real values. Never commit .env

# Database
MONGO_URI=mongodb://localhost:27017/osstel

# Auth (use long random strings in production)
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-use-openssl-rand-hex-32

# Optional: block public manager self-registration (recommended in production)
MANAGER_REGISTRATION_SECRET=

# Cron — required in production (Vercel / scheduled jobs)
CRON_SECRET=change-me-use-openssl-rand-hex-32

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Firebase push (optional — path or JSON inline)
# FIREBASE_SERVICE_ACCOUNT_PATH=
# GOOGLE_APPLICATION_CREDENTIALS=

# Google Sign-In (backend verifies ID tokens)
# GOOGLE_CLIENT_ID=
