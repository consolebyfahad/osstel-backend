# Server
PORT=5001
NODE_ENV=development

# Database (required)
MONGO_URI=mongodb://127.0.0.1:27017/osstel

# Auth (required)
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,https://www.osstel.site

# Production cron (required in production)
CRON_SECRET=change-me-cron-secret

# Restrict open manager registration in production
MANAGER_REGISTRATION_SECRET=change-me-manager-signup-secret

# Optional: Firebase service account JSON for FCM push (single line or file path)
# FIREBASE_SERVICE_ACCOUNT=
